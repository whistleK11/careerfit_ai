# .env.example

# =========================
# API Keys
# =========================

GEMINI_API_KEY=your_gemini_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
HUGGINGFACE_TOKEN=your_huggingface_token_here


# =========================
# 실행 모드
# =========================

MOCK_MODE=false


# =========================
# 사용할 LLM 모델
# =========================

# 기본: 수업 권장 Gemini
LLM_MODEL=gemini-2.5-flash-lite

# 품질 우선 Gemini
# LLM_MODEL=gemini-2.5-flash

# Gemini 불가 시 Mistral
# LLM_MODEL=mistral-small-latest

# HuggingFace 사용 시 모델 ID까지 포함하는 방식 추천
# LLM_MODEL=huggingface:모델제공자/모델이름(예시)
# LLM_MODEL=huggingface:meta-llama/Llama-3.2-3B-Instruct
# LLM_MODEL=huggingface:Qwen/Qwen2.5-0.5B-Instruct
# LLM_MODEL=huggingface:mistralai/Mistral-7B-Instruct-v0.3

# 로컬 Ollama
# LLM_MODEL=ollama:llama3.2:3b

# Ollama 로컬 서버 주소
OLLAMA_BASE_URL=http://localhost:11434


